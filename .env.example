# Opcional. No macOS o cmon lê o token direto do Keychain do Claude Code
# (renovado automaticamente), então este arquivo NÃO é necessário.
#
# Use em Linux/CI, ou para forçar um token específico. Copie para .env:
#   security find-generic-password -s "Claude Code-credentials" -w \
#     | python3 -c "import sys,json;print(json.load(sys.stdin)['claudeAiOauth']['accessToken'])"
CLAUDE_OAUTH_TOKEN=sk-ant-oat01-...
