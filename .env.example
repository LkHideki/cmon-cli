# Optional. Preferred: store the token in the OS secure vault with `cmon token set`
# (cross-platform), or let cmon read the Claude Code credential if logged in.
#
# This file covers step 1 (env var) — good for CI or forcing a token.
# Extract the current token from Claude Code on macOS:
#   security find-generic-password -s "Claude Code-credentials" -w \
#     | python3 -c "import sys,json;print(json.load(sys.stdin)['claudeAiOauth']['accessToken'])"
CLAUDE_OAUTH_TOKEN=sk-ant-oat01-...
