# Optional. Preferred: store the token in the OS secure vault with `cmon token set`
# (cross-platform), or let cmon read the Claude Code credential if logged in.
#
# This file covers step 1 (env var) — good for CI or forcing a token.
# Extract the current token from Claude Code on macOS:
#   security find-generic-password -s "Claude Code-credentials" -w \
#     | python3 -c "import sys,json;print(json.load(sys.stdin)['claudeAiOauth']['accessToken'])"
CLAUDE_OAUTH_TOKEN=sk-ant-oat01-...

# --- Optional tuning (sane defaults; uncomment only to override) ---
# CMON_DB=usage.duckdb            # database path
# CMON_RETRIES=3                  # fetch retry attempts
# CMON_DEDUP_SECS=60              # dedup window for snapshots (seconds)
# CMON_ALERT_LEAD=60             # minutes before the 5h reset to alert
# CMON_ALERT_LEAD_WEEKLY=180     # minutes before the weekly reset to alert
# CMON_HOOK=                      # shell command run on the time-based alert ($CMON_ALERT_MSG)
# CMON_OAUTH_CLIENT_ID=...        # OAuth client id used for token refresh
# CMON_OAUTH_TOKEN_URL=...        # OAuth token endpoint — must be a *.anthropic.com host
# CMON_ALLOW_PLAINTEXT_KEYRING=1  # allow `token set` on a cleartext keyring backend (headless)
# CMON_TZ=America/Sao_Paulo       # display timestamps in this IANA tz instead of UTC
#                                  # (quick override, doesn't persist; 'cmon config set timezone' does)
